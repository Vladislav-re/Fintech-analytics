              <calculation class='tableau' formula='{ FIXED : MAX(IF [ks] = { FIXED : MAX([ks]) } THEN [rejected_good] END) }' />
            </column>
            <column caption='Rejected total (KS)' datatype='integer' name='[Calculation_2251799821950074896]' role='measure' type='quantitative'>
