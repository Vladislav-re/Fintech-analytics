      <aliases enabled='yes' />
      <column caption='remaining_balance_default' datatype='real' name='[Calculation_162974018332774400]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[mean_loan_default]*POWER(1+[r_monthly],[Parameters].[Parameter 1])-[mean_ann_default]*&#13;&#10;(POWER(1+[r_monthly],[Parameters].[Parameter 1])-1)/[r_monthly]' />
      </column>
      <column caption='principal_paid_default' datatype='real' name='[Calculation_162974018339262465]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[mean_loan_default]-[Calculation_162974018332774400]' />
      </column>
      <column caption='interest_received_bef_default' datatype='real' name='[Calculation_162974018339471362]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[mean_ann_default]*[Parameters].[Parameter 1]-[Calculation_162974018339262465]' />
      </column>
      <column caption='loss_per_default' datatype='real' name='[Calculation_162974018339815427]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_162974018332774400]*[Parameters].[default period (copy)]-[Calculation_162974018339471362]' />
      </column>
      <column caption='collection_cost_default' datatype='real' name='[Calculation_162974018341900292]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[mean_loan_default]*[Parameters].[Loss Given Default (LGD) (copy)]' />
      </column>
      <column caption='profit_per_cured_default' datatype='real' name='[Calculation_162974018342039557]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[interest_default]-[Calculation_162974018341900292]' />
      </column>
      <column caption='net_profit' datatype='real' name='[Calculation_162974018345103366]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[approved_good]*[interest_good]-[approved_default]*[Parameters].[default period (copy 2)]*[Calculation_162974018339815427]+[approved_default]*(1-[Parameters].[default period (copy 2)])*[Calculation_162974018342039557]' />
      </column>
      <column caption='baseline' datatype='integer' name='[Calculation_162974018364260359]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [fpr] = {MIN([fpr])} THEN 0 &#13;&#10;ELSEIF [fpr] = {MAX([fpr])} THEN 1 &#13;&#10;END' />
      </column>
      <column caption='Max KS' datatype='real' name='[Calculation_162974018388357128]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [fpr] = { FIXED : MAX(IF [tpr] - [fpr] = { FIXED : MAX([tpr] - [fpr]) } THEN [fpr] END) }&#13;&#10;THEN [tpr] - [fpr]&#13;&#10;END' />
      </column>
      <column caption='Max KS Line Position' datatype='real' name='[Calculation_162974018423701513]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [tpr] - [fpr] = { FIXED : MAX([tpr] - [fpr]) } THEN [fpr] END) }' />
      </column>
      <column caption='Max profit' datatype='real' name='[Calculation_1674776119291592704]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_162974018345103366] = { FIXED : MAX(IF [Calculation_162974018345103366] = { FIXED : MAX([Calculation_162974018345103366]) } THEN [Calculation_162974018345103366] END) }&#13;&#10;THEN [Calculation_162974018345103366]/1e6&#13;&#10;END' />
      </column>
      <column caption='Max profit line' datatype='real' name='[Calculation_1674776119292100609]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [Calculation_162974018345103366] = { FIXED : MAX([Calculation_162974018345103366]) } THEN [Calculation_162974018345103366] END) }' />
      </column>
      <column caption='Max profit line by threshold' datatype='real' name='[Calculation_1674776119295115266]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [Calculation_162974018345103366] = { FIXED : MAX([Calculation_162974018345103366]) } THEN [threshold] END) }' />
      </column>
      <column caption='Threshold at Max Profit' datatype='real' name='[Calculation_2251799821944020994]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [Calculation_162974018345103366] = { FIXED : MAX([Calculation_162974018345103366]) } THEN [threshold] END) }' />
      </column>
      <column caption='TPR max profit' datatype='real' name='[Calculation_2251799821946441731]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [Calculation_162974018345103366] = { FIXED : MAX([Calculation_162974018345103366]) } THEN [tpr] END) }' />
      </column>
      <column caption='FPR max profit' datatype='real' name='[Calculation_2251799821946630148]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [Calculation_162974018345103366] = { FIXED : MAX([Calculation_162974018345103366]) } THEN [fpr] END) }' />
      </column>
      <column caption='Rejected real def' datatype='integer' name='[Calculation_2251799821946851333]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [Calculation_162974018345103366] = { FIXED : MAX([Calculation_162974018345103366]) } THEN [rejected_default] END) }' />
      </column>
      <column caption='Rejected not def' datatype='integer' name='[Calculation_2251799821947011078]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [Calculation_162974018345103366] = { FIXED : MAX([Calculation_162974018345103366]) } THEN [rejected_good] END) }' />
      </column>
      <column caption='Rejected total' datatype='integer' name='[Calculation_2251799821947936775]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2251799821947011078]+[Calculation_2251799821946851333]' />
      </column>
      <column caption='KS profit' datatype='real' name='[Calculation_2251799821948387336]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [ks] = { FIXED : MAX([ks]) } THEN [Calculation_162974018345103366]/1e6 END) }' />
      </column>
      <column caption='Threshold at KS' datatype='real' name='[Calculation_2251799821948768266]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [ks] = { FIXED : MAX([ks]) } THEN [threshold] END) }' />
      </column>
      <column caption='TPR KS' datatype='real' name='[Calculation_2251799821949255692]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [ks] = { FIXED : MAX([ks]) } THEN [tpr] END) }' />
