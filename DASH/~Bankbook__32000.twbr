            </column>
            <column caption='FPR KS' datatype='real' name='[Calculation_2251799821949403149]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX(IF [ks] = { FIXED : MAX([ks]) } THEN [fpr] END) }' />
            </column>
            <column caption='Rejected real def (KS)' datatype='integer' name='[Calculation_2251799821949698062]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX(IF [ks] = { FIXED : MAX([ks]) } THEN [rejected_default] END) }' />
            </column>
