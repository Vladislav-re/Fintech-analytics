    <worksheet name='KPIs max profit (KS) (add)'>
      <table>
        <view>
          <datasources>
            <datasource caption='tableau_roc_full' name='federated.00yskzv0q6dtgd12ynqpu0m3e7p6' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='collection_cost_rate' datatype='real' default-format='p0%' name='[Loss Given Default (LGD) (copy)]' param-domain-type='range' role='measure' type='quantitative' value='0.05'>
              <calculation class='tableau' formula='0.05' />
              <range granularity='0.01' max='0.2' min='0.0' />
            </column>
            <column caption='default period' datatype='integer' name='[Parameter 1]' param-domain-type='range' role='measure' type='quantitative' value='12'>
              <calculation class='tableau' formula='12' />
              <range granularity='1' max='36' min='2' />
            </column>
            <column caption='true_default_share' datatype='real' name='[default period (copy 2)]' param-domain-type='range' role='measure' type='quantitative' value='0.65'>
              <calculation class='tableau' formula='0.65' />
              <range granularity='0.05' max='1.0' min='0.0' />
            </column>
            <column caption='Loss Given Default (LGD)' datatype='real' name='[default period (copy)]' param-domain-type='range' role='measure' type='quantitative' value='0.8'>
              <calculation class='tableau' formula='0.8' />
              <range granularity='0.05' max='1.0' min='0.0' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.00yskzv0q6dtgd12ynqpu0m3e7p6'>
            <column caption='remaining_balance_default' datatype='real' name='[Calculation_162974018332774400]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[mean_loan_default]*POWER(1+[r_monthly],[Parameters].[Parameter 1])-[mean_ann_default]*&#13;&#10;(POWER(1+[r_monthly],[Parameters].[Parameter 1])-1)/[r_monthly]' />
            </column>
            <column caption='principal_paid_default' datatype='real' name='[Calculation_162974018339262465]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[mean_loan_default]-[Calculation_162974018332774400]' />
            </column>
            <column caption='interest_received_bef_default' datatype='real' name='[Calculation_162974018339471362]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[mean_ann_default]*[Parameters].[Parameter 1]-[Calculation_162974018339262465]' />
            </column>
            <column caption='loss_per_default' datatype='real' name='[Calculation_162974018339815427]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_162974018332774400]*[Parameters].[default period (copy)]-[Calculation_162974018339471362]' />
            </column>
            <column caption='collection_cost_default' datatype='real' name='[Calculation_162974018341900292]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[mean_loan_default]*[Parameters].[Loss Given Default (LGD) (copy)]' />
            </column>
            <column caption='profit_per_cured_default' datatype='real' name='[Calculation_162974018342039557]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[interest_default]-[Calculation_162974018341900292]' />
            </column>
            <column caption='net_profit' datatype='real' name='[Calculation_162974018345103366]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[approved_good]*[interest_good]-[approved_default]*[Parameters].[default period (copy 2)]*[Calculation_162974018339815427]+[approved_default]*(1-[Parameters].[default period (copy 2)])*[Calculation_162974018342039557]' />
            </column>
            <column caption='KS profit' datatype='real' name='[Calculation_2251799821948387336]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX(IF [ks] = { FIXED : MAX([ks]) } THEN [Calculation_162974018345103366]/1e6 END) }' />
            </column>
            <column caption='Threshold at KS' datatype='real' name='[Calculation_2251799821948768266]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX(IF [ks] = { FIXED : MAX([ks]) } THEN [threshold] END) }' />
            </column>
            <column caption='TPR KS' datatype='real' name='[Calculation_2251799821949255692]' role='measure' type='quantitative'>
